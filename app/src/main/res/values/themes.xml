<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/values/themes.xml -->
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Cyberpunk Dark Theme (Default) -->
    <style name="Theme.HappySappy" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/rainbow_blue</item>
        <item name="colorPrimaryVariant">@color/rainbow_purple</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/rainbow_purple</item>
        <item name="colorSecondaryVariant">@color/rainbow_red</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/background_card_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
        
        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:textColorHint">@color/text_hint_dark</item>

        <!-- Edit text style -->
        <item name="editTextStyle">@style/EditText.HappySappy.Cyber</item>

        <!-- Button style -->
        <item name="materialButtonStyle">@style/Button.HappySappy.Cyber</item>
        
        <!-- Card view style -->
        <item name="materialCardViewStyle">@style/CardView.HappySappy.Cyber</item>
    </style>

    <!-- Dark Theme (Explicit Alias) -->
    <style name="Theme.HappySappy.Dark" parent="Theme.HappySappy" />

    <!-- Cyberpunk Edit Text Style -->
    <style name="EditText.HappySappy.Cyber" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/rainbow_blue</item>
        <item name="boxBackgroundColor">@color/background_dark</item>
        <item name="hintTextColor">@color/text_secondary_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Cyberpunk Button Style -->
    <style name="Button.HappySappy.Cyber" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/rainbow_blue</item>
        <item name="android:textColor">@color/black</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-condensed-medium</item>
    </style>

    <!-- Cyberpunk Card View Style -->
    <style name="CardView.HappySappy.Cyber" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card_dark</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/divider_dark</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="CardView.HappySappy.Dark" parent="CardView.HappySappy.Cyber" />

    <!-- Rainbow Progress Bar Style -->
    <style name="ProgressBar.HappySappy.Rainbow" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/progress_bar_rainbow</item>
        <item name="android:minHeight">6dp</item>
        <item name="android:maxHeight">6dp</item>
        <item name="android:indeterminate">false</item>
    </style>

    <!-- Navigation View Style -->
    <style name="Navigation.HappySappy" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/navigation_selected_dark</item>
        <item name="itemTextColor">@color/navigation_selected_dark</item>
        <item name="itemRippleColor">@color/ripple_dark</item>
        <item name="backgroundTint">@color/navigation_background_dark</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Dialog.HappySappy" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/rainbow_blue</item>
        <item name="colorPrimaryContainer">@color/background_surface_dark</item>
        <item name="colorOnPrimaryContainer">@color/text_primary_dark</item>
        <item name="android:background">@color/background_card_dark</item>
    </style>

    <style name="Dialog.HappySappy.Dark" parent="Dialog.HappySappy" />

    <!-- Toolbar Style -->
    <style name="Toolbar.HappySappy" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background_dark</item>
        <item name="titleTextColor">@color/rainbow_blue</item>
        <item name="subtitleTextColor">@color/text_secondary_dark</item>
        <item name="navigationIconTint">@color/rainbow_blue</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.HappySappy.Splash" parent="Theme.HappySappy">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
</resources>