<?xml version="1.0" encoding="utf-8"?>
<!-- File: res/drawable/progress_bar_rainbow.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="@color/background_surface_light" />
        </shape>
    </item>
    
    <!-- Progress with Rainbow Gradient -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp" />
                <gradient
                    android:angle="0"
                    android:startColor="@color/rainbow_red"
                    android:centerColor="@color/rainbow_yellow"
                    android:endColor="@color/rainbow_purple"
                    android:type="linear" />
            </shape>
        </clip>
    </item>
    
    <!-- Secondary Progress -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp" />
                <gradient
                    android:angle="0"
                    android:startColor="@color/rainbow_red_light"
                    android:centerColor="@color/rainbow_yellow_light"
                    android:endColor="@color/rainbow_purple_light"
                    android:type="linear" />
            </shape>
        </clip>
    </item>
</layer-list>